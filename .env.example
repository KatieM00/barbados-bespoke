# ============================================================
# BarbadosBespoke — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# Supabase — create a NEW project at supabase.com (separate from DayWeave)
VITE_SUPABASE_DATABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google Maps / Places — create a NEW API key restricted to this domain
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
GOOGLE_PLACES_API_KEY=your-google-places-api-key-here

# Google Generative AI (Gemini)
GEMINI_API_KEY=your-gemini-api-key-here

# App URL (set to your Netlify URL after deployment)
VITE_APP_URL=https://your-site-name.netlify.app
